generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SAAS LAYER ───────────────────────────────────────────────
model Plan {
  id              String   @id @default(uuid())
  name            String   // Basic, Standard, Premium
  maxUsers        Int
  maxDetainees    Int      // per month
  features        Json     // array of feature flags
  monthlyPrice    Decimal  @db.Decimal(10,2)
  createdAt       DateTime @default(now())
  stations        Station[]
}

model Station {
  id              String   @id @default(uuid())
  name            String
  code            String   @unique  // e.g. "BKO", "LAE"
  province        String
  district        String?
  address         String?
  phone           String?
  email           String?
  logoUrl         String?
  planId          String
  plan            Plan     @relation(fields: [planId], references: [id])
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt     DateTime?
  billingStartDate DateTime?
  billedUntil     DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
  detainees       Detainee[]
  cells           Cell[]
  auditLogs       AuditLog[]
  biometricsCaptured Biometric[]
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
}

// ─── USERS ────────────────────────────────────────────────────
model User {
  id              String   @id @default(uuid())
  stationId       String?  // null = super admin
  station         Station? @relation(fields: [stationId], references: [id])
  name            String
  badgeNumber     String?
  rank            String?
  email           String   @unique
  passwordHash    String
  role            UserRole @default(OFFICER)
  isActive        Boolean  @default(true)
  lastLogin       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  bookingsCreated Detainee[] @relation("CreatedBy")
  bookingsReleased Detainee[] @relation("ReleasedBy")
  auditLogs       AuditLog[]
  biometricsCaptured Biometric[]
}

enum UserRole {
  SUPER_ADMIN
  STATION_ADMIN
  DUTY_SERGEANT
  OFFICER
}

// ─── OFFENDER IDENTITY (persists across all stations & bookings) ──
model Offender {
  id              String   @id @default(uuid())
  offenderNumber  String   @unique  // e.g. OFF-2026-000412, assigned on first-ever booking

  // Core identity (best-known values, may be corrected over time)
  firstName       String
  lastName        String
  alias           String?
  dateOfBirth     DateTime?
  gender          Gender
  nationality     String   @default("Papua New Guinean")
  ethnicity       String?
  // Origin province/village — mirrors Detainee's own fields, kept here
  // too so the offender's origin is known on later bookings even if a
  // future booking's form doesn't re-collect it.
  originProvince  String?
  originVillage   String?

  // Biometric linkage
  biometrics      Biometric[]
  bookings        Detainee[]

  firstSeenAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([lastName, firstName])
}

// ─── BIOMETRIC RECORDS (shared across all stations) ────────────
model Biometric {
  id              String   @id @default(uuid())
  offenderId      String
  offender        Offender @relation(fields: [offenderId], references: [id])

  type            BiometricType
  // Face: embedding is a 128-float vector from face-api.js, stored as JSON array for portability
  faceEmbedding   Json?
  facePhotoUrl    String?  // stored photo used to generate the embedding

  // Fingerprint: Phase 1 stores the scanned image only, no matching yet
  fingerPosition  FingerPosition?
  fingerprintUrl  String?

  capturedAt      DateTime @default(now())
  capturedById    String
  capturedBy      User     @relation(fields: [capturedById], references: [id])
  capturedAtStationId String
  capturedAtStation   Station @relation(fields: [capturedAtStationId], references: [id])

  @@index([offenderId])
  @@index([type])
}

enum BiometricType {
  FACE
  FINGERPRINT
}

enum FingerPosition {
  LEFT_THUMB
  LEFT_INDEX
  LEFT_MIDDLE
  LEFT_RING
  LEFT_LITTLE
  RIGHT_THUMB
  RIGHT_INDEX
  RIGHT_MIDDLE
  RIGHT_RING
  RIGHT_LITTLE
}


model Cell {
  id              String   @id @default(uuid())
  stationId       String
  station         Station  @relation(fields: [stationId], references: [id])
  cellNumber      String
  capacity        Int      @default(4)
  type            CellType @default(GENERAL)
  isActive        Boolean  @default(true)
  detainees       Detainee[]

  @@unique([stationId, cellNumber])
}

enum CellType {
  GENERAL
  FEMALE
  JUVENILE
  HIGH_SECURITY
  MEDICAL
}

model Detainee {
  id              String   @id @default(uuid())
  stationId       String
  station         Station  @relation(fields: [stationId], references: [id])
  custodyNumber   String   // auto-generated e.g. BKO-2026-0001

  // Identity link — every booking points to one persistent Offender
  offenderId      String
  offender        Offender @relation(fields: [offenderId], references: [id])

  // How this offender was identified at this booking
  matchMethod     MatchMethod @default(MANUAL)
  matchConfidence Float?   // 0.0-1.0, null if manual entry or new offender

  // Personal details (snapshot at time of this booking — may differ slightly from Offender's record, e.g. updated address)
  firstName       String
  lastName        String
  alias           String?
  dateOfBirth     DateTime?
  gender          Gender
  nationality     String   @default("Papua New Guinean")
  ethnicity       String?
  address         String?
  // Residential suburb — chosen from the national Suburb reference
  // table (Province > District > Suburb), filtered to the booking
  // station's own province/district. Free-text `address` above still
  // exists for any additional detail (street, settlement name, etc.)
  residentialSuburb String?
  // Origin province/village — where the detainee is originally from,
  // distinct from where they currently reside. Province is a national
  // PNG_PROVINCES dropdown; village is free text since PNG has
  // thousands of villages with no standardized national list.
  originProvince  String?
  originVillage   String?
  phone           String?
  nextOfKin       String?
  nextOfKinPhone  String?
  
  // Booking
  bookingTime     DateTime @default(now())
  arrestingOfficer String
  arrestLocation  String?
  charges         String[]
  offense         String?
  offenseCategory OffenseCategory @default(OTHER)
  
  // Custody
  cellId          String?
  cell            Cell?    @relation(fields: [cellId], references: [id])
  status          CustodyStatus @default(IN_CUSTODY)
  riskLevel       RiskLevel @default(LOW)
  healthNotes     String?
  propertyList    Json?    // items taken into custody
  
  // Warrants & legal
  warrantNumber   String?
  courtDate       DateTime?
  bailAmount      Decimal? @db.Decimal(12,2)
  lawyerName      String?
  lawyerPhone     String?
  
  // Release
  releaseTime     DateTime?
  releaseReason   String?
  releasedById    String?
  releasedBy      User?    @relation("ReleasedBy", fields: [releasedById], references: [id])
  
  // Metadata
  createdById     String
  createdBy       User     @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Offline sync
  clientId        String?  // UUID generated client-side for offline sync
  syncedAt        DateTime?
  
  reviews         CustodyReview[]
  
  @@index([stationId, status])
  @@index([clientId])
  @@index([offenderId])
}

enum MatchMethod {
  FACE_MATCH       // matched via face recognition against existing offenders
  MANUAL           // officer searched/selected manually
  NEW_OFFENDER     // no match found, new identity created
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CustodyStatus {
  IN_CUSTODY
  RELEASED
  TRANSFERRED
  HOSPITALISED
  ESCAPED
  DECEASED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum OffenseCategory {
  VIOLENT
  PROPERTY
  DRUG
  TRAFFIC
  PUBLIC_ORDER
  SEXUAL
  FRAUD
  OTHER
}

model CustodyReview {
  id              String   @id @default(uuid())
  detaineeId      String
  detainee        Detainee @relation(fields: [detaineeId], references: [id])
  reviewType      String   // welfare_check, medical, legal_review
  notes           String
  reviewedAt      DateTime @default(now())
  reviewedBy      String
}

model AuditLog {
  id              String   @id @default(uuid())
  stationId       String
  station         Station  @relation(fields: [stationId], references: [id])
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  action          String
  entity          String
  entityId        String
  changes         Json?
  ipAddress       String?
  createdAt       DateTime @default(now())
  
  @@index([stationId, createdAt])
}

// ─── PNG GEOGRAPHY REFERENCE (national, managed by Super Admin) ────
//
// Replaces the earlier hardcoded JS list and the station-scoped
// suburbs field — both provinces/districts and suburbs now live here
// as real, editable database rows, manageable from a Super Admin page
// (with CSV bulk import) instead of requiring a code change or direct
// database edit to add/correct an entry.

model Province {
  id          String     @id @default(uuid())
  name        String     @unique
  districts   District[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model District {
  id          String     @id @default(uuid())
  name        String
  provinceId  String
  province    Province   @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  suburbs     Suburb[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([provinceId, name])
}

model Suburb {
  id          String     @id @default(uuid())
  name        String
  districtId  String
  district    District   @relation(fields: [districtId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([districtId, name])
}
